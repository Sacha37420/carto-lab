# ── Adresses ─────────────────────────────────────────────────────
PORT_BACKEND=8091
BACKEND_URL=http://localhost:8091
PORT_FRONTEND=4209
FRONTEND_URL=http://localhost:4209

# ── Base de données (PostGIS dédié — service "db" du docker-compose) ─────────
DB_HOST=carto-lab-db
DB_PORT=5432
DB_NAME=cartodb
DB_SCHEMA=carto_lab
DB_USER=cartouser
DB_PASSWORD=CHANGE_ME

# ── Django ───────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME
DEBUG=False
ALLOWED_HOSTS=*

# ── Reverse proxy (Caddy) ────────────────────────────────────────
SCRIPT_NAME=/carto-lab-api

# ── SSO Keycloak ─────────────────────────────────────────────────
KEYCLOAK_CLIENT_ID=carto-lab
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/ssolab
# Client public (SPA Angular) — Keycloak → Clients → carto-lab → Access type : Public
# Valid redirect URIs : http://localhost:4209/*

# ── URLs (propagées automatiquement par reset_url.sh) ────────────
PORT_KEYCLOAK=8080
SERVER_URL_LAN=http://192.168.1.X
SERVER_URL_WAN=http://VOTRE_IP_WAN
KEYCLOAK_URL=http://192.168.1.X:8080
KEYCLOAK_PUBLIC_URL=http://VOTRE_IP_WAN:8080

# ── HTTPS / Caddy ─────────────────────────────────────────────────────────────
DOMAIN=CHANGE_ME
